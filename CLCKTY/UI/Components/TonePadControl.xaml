<UserControl x:Class="CLCKTY.UI.Components.TonePadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="220"
             Height="220">
    <Grid>
        <Border CornerRadius="16"
                Background="#1A1E28"
                BorderBrush="#3A4A62"
                BorderThickness="1.2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="#18232E" />
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="#202D3A" />
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="#161D2A" />
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="#1E2432" />

                <Rectangle Stroke="#3A4A62"
                           StrokeThickness="1"
                           Grid.RowSpan="2"
                           Grid.ColumnSpan="2" />
            </Grid>
        </Border>

        <Canvas x:Name="InputSurface"
                Background="Transparent"
                MouseLeftButtonDown="InputSurface_MouseLeftButtonDown"
                MouseLeftButtonUp="InputSurface_MouseLeftButtonUp"
                MouseMove="InputSurface_MouseMove"
                SizeChanged="InputSurface_SizeChanged">
            <Ellipse x:Name="Thumb"
                     Width="20"
                     Height="20"
                     Fill="#36A7FF"
                     Stroke="#AEE1FF"
                     StrokeThickness="1.2"
                     Effect="{DynamicResource HoverGlowShadow}" />
        </Canvas>
    </Grid>
</UserControl>
