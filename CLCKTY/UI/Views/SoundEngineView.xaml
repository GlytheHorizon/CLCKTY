<UserControl x:Class="CLCKTY.UI.Views.SoundEngineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:CLCKTY.UI.Components"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border CornerRadius="14"
                Padding="16"
                Background="#171C28"
                BorderBrush="#2F3D56"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Active Profile"
                           VerticalAlignment="Center"
                           Foreground="#D8E3FF"
                           FontSize="14" />
                <ComboBox Grid.Column="1"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding Profiles}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedProfile}"
                          Background="#202A3A"
                          Foreground="#EAF2FF"
                          BorderBrush="#385071"
                          BorderThickness="1.1"
                          Padding="8,5"
                          MinWidth="240" />

                <TextBlock Grid.Column="3"
                           Text="Master Volume"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="#D8E3FF"
                           FontSize="14" />
                <Slider Grid.Column="4"
                        Minimum="0"
                        Maximum="1"
                        Value="{Binding MasterVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TickFrequency="0.01"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                    MinWidth="220" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border CornerRadius="14"
                    Padding="16"
                    Background="#171C28"
                    BorderBrush="#2F3D56"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tone Control"
                               Foreground="#EAF2FF"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Thock ↔ Clack / Soft ↔ Sharp"
                               Margin="0,4,0,12"
                               Foreground="#8EA7D2"
                               FontSize="12" />

                    <components:TonePadControl ToneX="{Binding ToneX, Mode=TwoWay}"
                                               ToneY="{Binding ToneY, Mode=TwoWay}"
                                               HorizontalAlignment="Center" />

                    <Grid Margin="0,14,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Thock"
                                   Foreground="#93A9D0"
                                   HorizontalAlignment="Left" />
                        <TextBlock Grid.Column="1"
                                   Text="Clack"
                                   Foreground="#93A9D0"
                                   HorizontalAlignment="Right" />
                    </Grid>

                    <TextBlock Text="Input Triggers"
                               Margin="0,8,0,10"
                               Foreground="#EAF2FF"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <StackPanel>
                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Spatial Audio"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding SpatialAudioEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Random Pitch"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding RandomPitchEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Key Press Sounds"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding KeyDownEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Key Release Sounds"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding KeyUpEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Mouse Left"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding MouseLeftEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Mouse Right"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding MouseRightEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <DockPanel Margin="0,3,0,3">
                            <TextBlock Text="Mouse Middle"
                                       Foreground="#D8E3FF"
                                       VerticalAlignment="Center" />
                            <CheckBox Style="{StaticResource SwitchToggleStyle}"
                                      IsChecked="{Binding MouseMiddleEnabled}"
                                      HorizontalAlignment="Right" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    CornerRadius="14"
                    Padding="16"
                    Background="#171C28"
                    BorderBrush="#2F3D56"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sound Assets"
                               Foreground="#EAF2FF"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <ListView Grid.Row="1"
                              Margin="0,12,0,0"
                              ItemsSource="{Binding ProfileAssets}"
                              SelectedItem="{Binding SelectedAsset}"
                              Background="#111722"
                              BorderBrush="#2D3A52"
                              BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name"
                                                Width="180"
                                                DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Badge"
                                                Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding Badge, Converter={StaticResource SoundBadgeToBrushConverter}}">
                                                <TextBlock Text="{Binding Badge}"
                                                           Foreground="#0F1420"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Protection"
                                                Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsDeletable, Converter={StaticResource BoolToProtectionTextConverter}}"
                                                       Foreground="#C4D6F5" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="2"
                               Margin="0,12,0,0">
                        <TextBlock Text="Stock assets are protected and cannot be deleted."
                                   Foreground="#89A3D1"
                                   VerticalAlignment="Center" />
                        <Button Content="Delete Selected"
                                DockPanel.Dock="Right"
                                Padding="14,7"
                                Margin="12,0,0,0"
                                Click="DeleteSelectedAsset_Click"
                                IsEnabled="{Binding CanDeleteSelectedAsset}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
