<UserControl x:Class="CLCKTY.UI.Views.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Border CornerRadius="14"
                Padding="18"
                Background="#171C28"
                BorderBrush="#2F3D56"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="CLCKTY"
                           Foreground="#EAF2FF"
                           FontSize="28"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding AppVersion, StringFormat=Version: {0}}"
                           Foreground="#A7C2EE"
                           FontSize="14" />

                <Grid Grid.Row="2"
                      Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="CPU"
                               Foreground="#D8E3FF"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            CornerRadius="8"
                            Padding="10,4"
                            Background="#202A3A">
                        <TextBlock Text="{Binding CpuUsagePercent, StringFormat={}{0:F1}%}"
                                   Foreground="#8FF0C9"
                                   FontFamily="Cascadia Mono"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Column="3"
                               Text="Engine Latency"
                               Foreground="#D8E3FF"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="4"
                            Margin="10,0,0,0"
                            CornerRadius="8"
                            Padding="10,4"
                            Background="#202A3A">
                        <TextBlock Text="{Binding EngineLatencyMs, StringFormat={}{0:F2} ms}"
                                   Foreground="#96D5FF"
                                   FontFamily="Cascadia Mono"
                                   HorizontalAlignment="Center" />
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Margin="0,18,0,0"
                           Foreground="#D8E3FF"
                           Text="Credits"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="4"
                           Margin="0,6,0,0"
                           Foreground="#9CB6DE"
                           TextWrapping="Wrap"
                           Text="Built with WPF + .NET 8 + NAudio. Designed for low-latency desktop interaction feedback." />

                <Border Grid.Row="5"
                        Margin="0,18,0,0"
                        CornerRadius="10"
                        Padding="12"
                        Background="#111826"
                        BorderBrush="#37527A"
                        BorderThickness="1">
                    <TextBlock Text="{Binding SafetyNote}"
                               Foreground="#9BD0FF"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
