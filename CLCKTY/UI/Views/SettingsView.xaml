<UserControl x:Class="CLCKTY.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Border CornerRadius="14"
                Padding="16"
                Background="#171C28"
                BorderBrush="#2F3D56"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Global Sounds"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Column="1"
                          Style="{StaticResource SwitchToggleStyle}"
                          IsChecked="{Binding SoundsEnabled}" />

                <TextBlock Grid.Row="1"
                           Text="Start With Windows"
                           Margin="0,12,0,0"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,12,0,0"
                          Style="{StaticResource SwitchToggleStyle}"
                          IsChecked="{Binding StartWithWindows}" />

                <TextBlock Grid.Row="2"
                           Text="Latency Mode"
                           Margin="0,12,0,0"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="14,12,0,0"
                          Width="180"
                          ItemsSource="{Binding LatencyModes}"
                          SelectedItem="{Binding LatencyMode}"
                          Background="#202A3A"
                          Foreground="#EAF2FF"
                          BorderBrush="#385071" />

                <TextBlock Grid.Row="3"
                           Text="Global Hotkey"
                           Margin="0,12,0,0"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Row="3"
                          Grid.Column="1"
                          Margin="0,12,0,0"
                          Style="{StaticResource SwitchToggleStyle}"
                          IsChecked="{Binding GlobalHotkeyEnabled}" />

                <TextBlock Grid.Row="4"
                           Text="Toggle Hotkey String"
                           Margin="0,12,0,0"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Margin="14,12,0,0"
                         Width="180"
                         Text="{Binding ToggleHotkey, UpdateSourceTrigger=PropertyChanged}"
                         Background="#202A3A"
                         Foreground="#EAF2FF"
                         BorderBrush="#385071"
                         Padding="8,6" />

                <TextBlock Grid.Row="5"
                           Text="Start Minimized To Tray"
                           Margin="0,12,0,0"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                <CheckBox Grid.Row="5"
                          Grid.Column="1"
                          Margin="0,12,0,0"
                          Style="{StaticResource SwitchToggleStyle}"
                          IsChecked="{Binding StartMinimizedToTray}" />

                <Grid Grid.Row="6"
                      Grid.ColumnSpan="2"
                      Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Record Slot"
                           Foreground="#D8E3FF"
                           VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                          Margin="14,0,10,0"
                          ItemsSource="{Binding RecordableSlots}"
                          SelectedItem="{Binding SelectedRecordingSlot}"
                          Background="#202A3A"
                          Foreground="#EAF2FF"
                          BorderBrush="#385071"
                          Padding="8,5" />
                    <Button Grid.Column="2"
                        Content="Record 1.2s Clip"
                        Padding="16,8"
                        Click="RecordClip_Click" />
                </Grid>

                <StackPanel Grid.Row="7"
                            Grid.ColumnSpan="2"
                            Margin="0,18,0,0"
                            Orientation="Horizontal">
                    <Button Content="Import Sound Pack"
                            Padding="16,8"
                            Click="ImportSoundPack_Click" />
                    <Button Content="Reset Configuration"
                            Padding="16,8"
                            Margin="10,0,0,0"
                            Click="ResetConfiguration_Click" />
                </StackPanel>

                <TextBlock Grid.Row="8"
                           Grid.ColumnSpan="2"
                           Margin="0,18,0,0"
                           Foreground="#90A8D0"
                           TextWrapping="Wrap"
                           Text="Import expects audio files in one folder. Name files with key_down, key_up, mouse_left, mouse_right, and mouse_middle for deterministic mapping." />
            </Grid>
        </Border>
    </Grid>
</UserControl>
