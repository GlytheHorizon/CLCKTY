<Window x:Class="CLCKTY.App.UI.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CLCKTY Stats"
        Width="700"
        Height="640"
        MinWidth="700"
        MaxWidth="700"
        MinHeight="640"
        MaxHeight="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />
        <SolidColorBrush x:Key="XpBarBackground" Color="#132A22" />
        <SolidColorBrush x:Key="XpBarFill" Color="#22D883" />
        <FontFamily x:Key="HeadingFont">/CLCKTY.App;component/Assets/Fonts/#Rajdhani</FontFamily>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E3FCF1" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="IconRoot" Property="Background" Value="#1D4937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#132A22" />
            <Setter Property="BorderBrush" Value="#1E5B46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E8FFF5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TitleRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TitleRoot" Property="Background" Value="#1A3D30" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TitleRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2A6A53"
                                BorderBrush="#3E8A6D"
                                BorderThickness="1"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#0E1D17" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="1">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="ScrollDecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="ScrollIncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#xE7FC;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <StackPanel Grid.Column="1">
                    <TextBlock Text="CLCKTY Stats"
                               FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Level up by clicking and typing!"
                               Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="2"
                        ToolTip="Close"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Level & XP Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="56" Height="56"
                                        CornerRadius="28"
                                        Background="#1A4A38"
                                        BorderBrush="#22D883"
                                        BorderThickness="2"
                                        Margin="0,0,14,0">
                                    <TextBlock x:Name="LevelDisplay"
                                               Text="1"
                                               FontFamily="{StaticResource HeadingFont}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Level "
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" />
                                        <TextBlock x:Name="LevelText"
                                                   Text="1"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="Bold"
                                                   FontSize="12" />
                                    </StackPanel>

                                    <!-- XP Bar -->
                                    <Grid Margin="0,6,0,0" Height="12">
                                        <Border CornerRadius="6"
                                                Background="{StaticResource XpBarBackground}" />
                                        <Border x:Name="XpBarFill"
                                                CornerRadius="6"
                                                Background="{StaticResource XpBarFill}"
                                                HorizontalAlignment="Left"
                                                Width="0" />
                                    </Grid>

                                    <TextBlock x:Name="XpText"
                                               Text="0 / 100 XP"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="14,0,0,0"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="Title"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Right" />
                                    <TextBlock x:Name="MainTitleText"
                                               Text="Newbie Clacker"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               HorizontalAlignment="Right" />
                                    <TextBlock x:Name="SecondaryTitleText"
                                               Text=""
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Clackity Stats Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Clackity Stats"
                                       Grid.ColumnSpan="2"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <!-- Total Clackity -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Text="Total Clackity"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="TotalClackityText"
                                           Text="0"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="Bold"
                                           FontSize="20" />
                            </StackPanel>

                            <!-- Today -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Text="Today"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="TodayClackityText"
                                           Text="0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"
                                           FontSize="20" />
                            </StackPanel>

                            <!-- This Week -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Text="This Week"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="WeekClackityText"
                                           Text="0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"
                                           FontSize="20" />
                            </StackPanel>

                            <!-- This Month -->
                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,8">
                                <TextBlock Text="This Month"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="MonthClackityText"
                                           Text="0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="Bold"
                                           FontSize="20" />
                            </StackPanel>

                            <!-- Keyboard clicks -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,4">
                                <TextBlock Text="Keyboard Clicks"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="KeyboardClicksText"
                                           Text="0"
                                           Foreground="#4FC3F7"
                                           FontWeight="Bold"
                                           FontSize="16" />
                            </StackPanel>

                            <!-- Mouse clicks -->
                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,4">
                                <TextBlock Text="Mouse Clicks"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="10" />
                                <TextBlock x:Name="MouseClicksText"
                                           Text="0"
                                           Foreground="#FF7043"
                                           FontWeight="Bold"
                                           FontSize="16" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Titles & Achievements Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Titles &amp; Achievements"
                                       FontFamily="{StaticResource HeadingFont}"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Click a title to set it as your main title"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10"
                                       Margin="0,2,0,8" />

                            <ScrollViewer MaxHeight="220"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="TitlesPanel">
                                    <!-- Titles are populated in code-behind -->
                                    <TextBlock Text="No titles unlocked yet. Start clicking!"
                                               Foreground="#5B8A76"
                                               FontStyle="Italic"
                                               FontSize="11"
                                               Margin="0,4,0,4" />
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Secret Achievements Hint -->
                    <Border Background="#0E1A15"
                            BorderBrush="#1A3D30"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#AB47BC"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <StackPanel>
                                <TextBlock Text="Secret Achievements"
                                           Foreground="#AB47BC"
                                           FontWeight="SemiBold"
                                           FontSize="12" />
                                <TextBlock Text="Hidden titles exist. Keep clicking to discover them..."
                                           Foreground="#7B6F8A"
                                           FontSize="10" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
