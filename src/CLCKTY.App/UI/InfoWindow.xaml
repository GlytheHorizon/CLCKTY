<Window x:Class="CLCKTY.App.UI.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information"
        Width="620"
        Height="560"
        MinWidth="620"
        MaxWidth="620"
        MinHeight="560"
        MaxHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E3FCF1" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="IconRoot" Property="Background" Value="#1D4937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Information"
                               FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="About CLCKTY"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        ToolTip="Close information"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="CLCKTY v1.2.0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Build 041826P"
                                       Margin="0,2,0,0"
                                       Foreground="{StaticResource AccentBrush}" />

                            <TextBlock Margin="0,16,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                CLCKTY transforms your typing into sound&#8212;turning every keystroke into a customizable audio experience. Designed to be lightweight, responsive, and always running in the background.
                            </TextBlock>

                            <TextBlock Margin="0,16,0,0"
                                       Text="Developed by Jerwin Cruz"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                    Text="Inspired by Keeby by Adrian Angelo Abelarde (Keeby)"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            <TextBlock Margin="18,0,0,0"
                                    Text="Hai Nguyen (Mechvibes)"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="Wrap" />

                            <TextBlock Margin="0,16,0,0"
                                       Text="Features:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="&#x2022; (add features here)"
                                       Foreground="{StaticResource TextSecondaryBrush}" />

                            <TextBlock Margin="0,16,0,0"
                                       Text="Privacy:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                CLCKTY does not record, store, or transmit any keystrokes. All input is used solely to trigger sound playback.
                            </TextBlock>

                            <TextBlock Margin="0,16,0,0"
                                       Text="Built with C# (.NET) and WPF"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="Audio powered by NAudio"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Margin="0,18,0,0"
                                       Text="&#8220;Not just typing&#8230; performing.&#8221;"
                                       FontStyle="Italic"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
