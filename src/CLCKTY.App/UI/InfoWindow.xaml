<Window x:Class="CLCKTY.App.UI.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Information"
        Width="620"
        Height="560"
        MinWidth="620"
        MaxWidth="620"
        MinHeight="560"
        MaxHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E3FCF1" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="IconRoot" Property="Background" Value="#1D4937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#12392C" />
            <Setter Property="BorderBrush" Value="#2A6A53" />
        </Style>

        <Style x:Key="InfoScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2AAE79"
                                BorderBrush="#43D79D"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="#0E1C17" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="1">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InfoScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Information"
                               FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="About CLCKTY"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        ToolTip="Close information"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar"
                           BasedOn="{StaticResource InfoScrollBarStyle}" />
                </ScrollViewer.Resources>
                <StackPanel>
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="CLCKTY v1.2.0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Build 041826P"
                                       Margin="0,2,0,0"
                                       Foreground="{StaticResource AccentBrush}" />

                            <TextBlock Margin="0,16,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                CLCKTY transforms your typing into sound&#8212;turning every keystroke into a customizable audio experience. Designed to be lightweight, responsive, and always running in the background.
                            </TextBlock>

                            <TextBlock Margin="0,16,0,0"
                                       Text="Developed by Jerwin Cruz"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                    Text="Inspired by Adrian Angelo Abelarde (Keeby)"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Hai Nguyen (Mechvibes)"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center" />

                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        ToolTip="Open MechvibesDX on GitHub"
                                        Style="{StaticResource LinkIconButtonStyle}"
                                        Click="OpenMechvibesGithubButton_Click">
                                    <Viewbox Width="14" Height="14">
                                        <Path Fill="#E8FFF5"
                                              Stretch="Uniform"
                                              Data="M8,0.5C3.86,0.5 0.5,3.86 0.5,8C0.5,11.31 2.65,14.11 5.63,15.1C6.01,15.17 6.14,14.94 6.14,14.75C6.14,14.58 6.13,14.02 6.12,13.34C4.03,13.79 3.59,12.44 3.59,12.44C3.25,11.58 2.77,11.35 2.77,11.35C2.1,10.89 2.82,10.9 2.82,10.9C3.56,10.95 3.95,11.66 3.95,11.66C4.61,12.79 5.69,12.47 6.11,12.28C6.18,11.8 6.36,11.47 6.56,11.28C4.89,11.09 3.14,10.44 3.14,7.55C3.14,6.73 3.43,6.06 3.91,5.53C3.84,5.34 3.58,4.57 3.99,3.52C3.99,3.52 4.62,3.32 6.14,4.35C6.74,4.18 7.39,4.1 8.03,4.1C8.67,4.1 9.32,4.18 9.92,4.35C11.44,3.32 12.07,3.52 12.07,3.52C12.48,4.57 12.22,5.34 12.15,5.53C12.63,6.06 12.92,6.73 12.92,7.55C12.92,10.45 11.17,11.09 9.5,11.28C9.75,11.49 9.97,11.91 9.97,12.56C9.97,13.5 9.96,14.44 9.96,14.75C9.96,14.94 10.09,15.17 10.48,15.1C13.45,14.11 15.5,11.31 15.5,8C15.5,3.86 12.14,0.5 8,0.5Z" />
                                    </Viewbox>
                                </Button>
                            </Grid>

                            <TextBlock Margin="0,16,0,0"
                                       Text="Features:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="&#x2022; Global keyboard and mouse sound playback with low latency"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="&#x2022; Separate keyboard and mouse profiles with independent routing"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="&#x2022; Import Mechvibes-style packs and map per-key or per-button sounds"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="&#x2022; Custom audio upload for specific key and mouse mappings"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="&#x2022; Live trigger preview, profile switching, and activity monitoring"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="&#x2022; Tray controls, startup option, and global toggle hotkeys"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,16,0,0"
                                       Text="Privacy:"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                CLCKTY does not record, store, or transmit any keystrokes. All input is used solely to trigger sound playback.
                            </TextBlock>

                            <TextBlock Margin="0,16,0,0"
                                       Text="Built with C# (.NET) and WPF"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="0,2,0,0"
                                       Text="Audio powered by NAudio"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Margin="0,18,0,0"
                                       Text="&#8220;Not just typing&#8230; performing.&#8221;"
                                       FontStyle="Italic"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
