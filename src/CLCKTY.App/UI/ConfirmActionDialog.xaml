<Window x:Class="CLCKTY.App.UI.ConfirmActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Action"
        Width="430"
        Height="230"
        MinWidth="430"
        MaxWidth="430"
        MinHeight="230"
        MaxHeight="230"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#14110F" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#5A2A24" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1F1714" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#6A342D" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFEDE9" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#E9B9AF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E06556" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#2C201C" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="#73443B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#C37367" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#3A2A25" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#5B2621" />
            <Setter Property="BorderBrush" Value="#C45B50" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="16"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Text="Confirm Action"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Please confirm to continue."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="This action cannot be undone."
                               Foreground="{StaticResource DangerBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="MessageText"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        MinWidth="96"
                        Content="Cancel"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="CancelButton_Click" />

                <Button Grid.Column="3"
                        x:Name="ConfirmButton"
                        MinWidth="132"
                        Content="Confirm"
                        Style="{StaticResource DangerActionButtonStyle}"
                        Click="ConfirmButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
