<Window x:Class="CLCKTY.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="480"
        Height="620"
        MinWidth="480"
        MaxWidth="480"
        MinHeight="620"
        MaxHeight="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E3FCF1" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="IconRoot" Property="Background" Value="#1D4937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="14"
                                    Background="#244437" />
                            <Border x:Name="Thumb"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="#E8FFF5"
                                    Margin="3"
                                    HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="24"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#123025" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#2A6A53" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#1A4A38" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10221B" />
            <Setter Property="BorderBrush" Value="#2B6D56" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />
                            <Grid Margin="10,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  SnapsToDevicePixels="True" />
                                <Path Grid.Column="1"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#9CD9C2"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#0E1D17"
                                        BorderBrush="#2B6D56"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#D9F6EB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#144131" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A5A43" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2A6A53"
                                BorderBrush="#3E8A6D"
                                BorderThickness="1"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#0E1D17" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="1">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Settings"
                               FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Startup, sound, and audio device controls"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        ToolTip="Close settings"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Start With Windows -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Start With Windows"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Launch CLCKTY automatically when you sign in."
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Sound"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="2,0,0,8" />

                    <!-- Master Engine -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Master Engine"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Turn all CLCKTY sound playback on or off."
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <!-- Keyboard Sounds -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Keyboard Sounds"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Enable or mute keyboard-triggered clips."
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsKeyboardSoundEnabled, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <!-- Mouse Sounds -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Mouse Sounds"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Enable or mute mouse-triggered clips."
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsMouseSoundEnabled, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <!-- Spatial Sound -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE995;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{StaticResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Spatial Sound"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="Simulate spatial audio positioning for a more immersive typing experience. Uses stereo panning."
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleButton x:Name="SpatialSoundToggle"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Style="{StaticResource SwitchStyle}"
                                          IsChecked="False" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Audio Device"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="2,0,0,8" />

                    <!-- Output Device -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="&#xE7F5;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Output Device"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Select which audio output device CLCKTY uses."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap" />
                            <ComboBox x:Name="OutputDeviceComboBox"
                                      SelectionChanged="OutputDeviceComboBox_SelectionChanged" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Performance"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="2,0,0,8" />

                    <!-- Latency Analyzer + Optimizer -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE916;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Latency Analyzer"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Measures and optimizes audio output latency for the best response time."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,10"
                                       TextWrapping="Wrap" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Current"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="CurrentLatencyText"
                                               Text="60 ms"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Buffers"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="BufferCountText"
                                               Text="3"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="Bold"
                                               FontSize="18"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Status"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="LatencyStatusText"
                                               Text="Good"
                                               Foreground="#8BC34A"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="AnalyzeLatencyButton"
                                        Style="{StaticResource GlowButtonStyle}"
                                        Click="AnalyzeLatencyButton_Click"
                                        Padding="10,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9D9;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Analyze"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="OptimizeLatencyButton"
                                        Grid.Column="2"
                                        Style="{StaticResource GlowButtonStyle}"
                                        Click="OptimizeLatencyButton_Click"
                                        Padding="10,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE771;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Optimize"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock Grid.Row="3"
                       Margin="2,10,0,0"
                       Text="Changes are applied instantly."
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </Grid>
    </Border>
</Window>
