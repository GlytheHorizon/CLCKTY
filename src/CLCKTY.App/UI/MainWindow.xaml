<Window x:Class="CLCKTY.App.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CLCKTY.App.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:CLCKTY.App.UI"
        mc:Ignorable="d"
        Title="CLCKTY"
        Width="460"
        Height="680"
        MinWidth="460"
        MaxWidth="460"
        MinHeight="680"
        MaxHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Opacity="0">
    <Window.Resources>
        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#141820" Offset="0.0" />
            <GradientStop Color="#11141B" Offset="0.55" />
            <GradientStop Color="#1A1D2B" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F6F8FF" />
            <Setter Property="Background" Value="#242C3D" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#3A4663" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#4F6BFF" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#2B3651" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="14"
                                    Background="#313949" />
                            <Border x:Name="Thumb"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="#EDF0FF"
                                    Margin="3"
                                    HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#4F6BFF" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="24"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F4F6FF" />
            <Setter Property="Background" Value="#1E2432" />
            <Setter Property="BorderBrush" Value="#2F3950" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#DDE8FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2338" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3550" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProfileItemTemplate" DataType="{x:Type core:SoundProfileDescriptor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DisplayName}"
                           Foreground="#EAF1FF"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0" />

                <Border Grid.Column="1"
                        Padding="7,2"
                        CornerRadius="8"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1F3145" />
                            <Setter Property="BorderBrush" Value="#3E6C9E" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImported}" Value="True">
                                    <Setter Property="Background" Value="#243A28" />
                                    <Setter Property="BorderBrush" Value="#4D9A64" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SourceLabel}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#E8F1FF" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MappingRowTemplate" DataType="{x:Type ui:KeyMappingRowViewModel}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding InputOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding InputCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <ComboBox Grid.Column="1"
                          SelectedValuePath="Tag"
                          SelectedValue="{Binding MappingTrigger, Mode=TwoWay}"
                          Margin="8,0,0,0">
                    <ComboBoxItem Tag="{x:Static core:KeyEventTrigger.Down}">Down</ComboBoxItem>
                    <ComboBoxItem Tag="{x:Static core:KeyEventTrigger.Up}">Up</ComboBoxItem>
                </ComboBox>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Options}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedClipId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Margin="8,0,0,0" />

                <Button Grid.Column="3"
                        Content="Audio"
                        Command="{Binding DataContext.ImportMappingAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}" />

                <Button Grid.Column="4"
                        Content="-"
                        Command="{Binding DataContext.RemoveMappingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="22"
            BorderBrush="#2F3950"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#0A0D15"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.75" />
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1C2231"
                    BorderBrush="#32405A"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="CLCKTY"
                                   FontSize="24"
                                   FontFamily="Segoe UI Semibold"
                                   Foreground="#EFF3FF" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#7A8498" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Fill" Value="#2CE086" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock FontSize="12"
                                       Foreground="#9FAED0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Muted" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Text" Value="Active" />
                                                <Setter Property="Foreground" Value="#B5C8FF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="14,0,12,0"
                                VerticalAlignment="Center">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Master"
                                       FontSize="10"
                                       Foreground="#AFC1E8"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Key"
                                       FontSize="10"
                                       Foreground="#AFC1E8"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsKeyboardSoundEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Mouse"
                                       FontSize="10"
                                       Foreground="#AFC1E8"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsMouseSoundEnabled, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="28"
                            Height="28"
                            Content="X"
                            FontSize="12"
                            Style="{StaticResource GlowButtonStyle}"
                            Click="HideButton_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Sound Profile"
                           FontSize="12"
                           Foreground="#A7B4D4"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="0,0,10,0">
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  ItemTemplate="{StaticResource ProfileItemTemplate}"
                                  MinHeight="38"
                                  Padding="10,6,88,6" />

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,32,0"
                                Padding="8,2"
                                CornerRadius="8"
                                BorderThickness="1"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1F3145" />
                                    <Setter Property="BorderBrush" Value="#3E6C9E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProfile.IsImported}" Value="True">
                                            <Setter Property="Background" Value="#243A28" />
                                            <Setter Property="BorderBrush" Value="#4D9A64" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedProfile.SourceLabel}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#E8F1FF" />
                        </Border>
                    </Grid>

                    <Button Grid.Column="1"
                            Content="Import Pack"
                            Command="{Binding ImportSoundPackCommand}"
                            Style="{StaticResource GlowButtonStyle}"
                            MinHeight="38" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Volume"
                           FontSize="12"
                           Foreground="#A7B4D4"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Foreground="#4F6BFF" />

                    <Border Grid.Column="1"
                            Background="#1E2536"
                            CornerRadius="8"
                            BorderBrush="#37445E"
                            BorderThickness="1"
                            Padding="10,6">
                        <TextBlock Foreground="#D9E4FF"
                                   FontWeight="SemiBold"
                                   Text="{Binding Volume, StringFormat={}{0:0}%}" />
                    </Border>
                </Grid>

                <CheckBox Margin="2,10,0,0"
                          Foreground="#B4C1DF"
                          IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                          Content="Start with Windows" />
            </StackPanel>

            <Border Grid.Row="6"
                    Background="#171D2B"
                    BorderBrush="#2F3A53"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <TabControl Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="#BFD0F8" />
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Margin" Value="0,0,6,0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#EFF4FF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="Sound">
                        <StackPanel Margin="4,10,4,4">
                            <TextBlock Text="Use the profile dropdown to switch between stock and imported packs instantly."
                                       Foreground="#CEDBFF"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,10,0,0"
                                    Background="#132331"
                                    BorderBrush="#2E5F86"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Current Source"
                                               Foreground="#AFC3EC"
                                               Margin="0,0,8,0" />
                                    <Border Padding="8,2"
                                            CornerRadius="8"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1F3145" />
                                                <Setter Property="BorderBrush" Value="#3E6C9E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedProfile.IsImported}" Value="True">
                                                        <Setter Property="Background" Value="#243A28" />
                                                        <Setter Property="BorderBrush" Value="#4D9A64" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding SelectedProfile.SourceLabel}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E8F1FF" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="Map any key or mouse button in the Key Mapping tab and assign Down or Up with default clips or imported audio."
                                       Foreground="#9FB3D8"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Key Mapping">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,10,4,4">
                                <TextBlock Text="Keyboard Mappings"
                                           Foreground="#EAF0FF"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Pick any virtual key, set Down or Up, then choose a clip or import an audio file."
                                           Foreground="#96A8CD"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Content="Add Keyboard Mapping"
                                        Command="{Binding AddKeyboardMappingCommand}"
                                        HorizontalAlignment="Left"
                                        MinHeight="32"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}" />

                                <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />

                                <Border Height="1"
                                        Margin="0,10,0,10"
                                        Background="#2A344D" />

                                <TextBlock Text="Mouse Mappings"
                                           Foreground="#EAF0FF"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Map left, right, middle, or side mouse buttons with separate Down and Up sounds."
                                           Foreground="#96A8CD"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Content="Add Mouse Mapping"
                                        Command="{Binding AddMouseMappingCommand}"
                                        HorizontalAlignment="Left"
                                        MinHeight="32"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}" />

                                <ItemsControl ItemsSource="{Binding MouseMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />

                                <Button Content="Clear Custom Mappings"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ClearMappingsCommand}"
                                        Style="{StaticResource GlowButtonStyle}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="8"
                    Background="#121725"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#293246"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#CBDAFF"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="CLCKTY only triggers playback and never logs typing."
                               Foreground="#8FA0C4"
                               FontSize="11"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
