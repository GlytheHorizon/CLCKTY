                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#161D1B"
                                        Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="260" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="#111E19"
                                                CornerRadius="8"
                                                Padding="10,8"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE790;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="Mode"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Border x:Name="ModeNormalBtn"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Margin="0,0,4,0"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="ModeNormal_Click">
                                                        <TextBlock Text="Normal"
                                                                   Foreground="#07241A"
                                                                   FontSize="10"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                    <Border x:Name="ModeMeetingBtn"
                                                            Background="#1A3D30"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Margin="0,0,4,0"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="ModeMeeting_Click">
                                                        <TextBlock Text="Meeting"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border x:Name="ModeGamingBtn"
                                                            Background="#1A3D30"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Margin="0,0,4,0"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="ModeGaming_Click">
                                                        <TextBlock Text="Gaming"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border x:Name="ModeSilentBtn"
                                                            Background="#1A3D30"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="ModeSilent_Click">
                                                        <TextBlock Text="Silent"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="Current Configuration"
                                                       FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                       FontSize="10"
                                                       Foreground="#7EB09A"
                                                       FontWeight="SemiBold" />

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Keyboard Profile"
                                                               Foreground="#7EB09A"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedKeyboardProfile.DisplayName, FallbackValue=Keyboard Profile}"
                                                               Margin="0,2,0,0"
                                                               FontSize="22"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="#173629"
                                                        BorderBrush="#2A7C5E"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10,3"
                                                        Margin="10,6,0,0"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding SelectedKeyboardProfile.SourceLabel, FallbackValue=Unknown Source}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="Mouse Profile"
                                                               Foreground="#7EB09A"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedMouseProfile.DisplayName, FallbackValue=Mouse Profile}"
                                                               Margin="0,2,0,0"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="#173629"
                                                        BorderBrush="#2A7C5E"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10,3"
                                                        Margin="10,2,0,0"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding SelectedMouseProfile.SourceLabel, FallbackValue=Unknown Source}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="Dashboard view is read-only. Use Sound Profiles and Mapping pages to edit settings."
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Row="4"
                                                Background="#111E19"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="8"
                                                Padding="10,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Latest Actions"
                                                           FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13" />
                                                <TextBlock Grid.Row="1"
                                                           Text="Profile changes and mapping actions"
                                                           Foreground="#8DC4AE"
                                                           FontSize="11"
                                                           Margin="0,4,0,0" />

                                                <ScrollViewer Grid.Row="2"
                                                              Margin="0,8,0,0"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <ItemsControl ItemsSource="{Binding DashboardActivityFeed}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}"
                                                                           FontFamily="Consolas"
                                                                           Foreground="#CFECE0"
                                                                           FontSize="10"
                                                                           Margin="0,0,0,4"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#111917"
                                        Padding="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Live Input Keycap"
                                                           FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE9D9;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="13" />
                                            </Grid>

                                            <TextBlock Text="Press any key or mouse button."
                                                       Foreground="#8DC4AE"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />

                                            <Grid Height="118"
                                                  Margin="0,12,0,0">
                                                <Border x:Name="VisualizerKeycapShadow"
                                                        Width="114"
                                                        Height="84"
                                                        CornerRadius="8"
                                                        Background="#06110D"
                                                        Opacity="0.35"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,6" />

                                                <Border x:Name="VisualizerKeycap"
                                                        Width="114"
                                                        Height="84"
                                                        CornerRadius="8"
                                                        Background="#1D3329"
                                                        VerticalAlignment="Top"
                                                        HorizontalAlignment="Center"
                                                        BorderBrush="#2C5A47"
                                                        BorderThickness="1"
                                                        Padding="0,8,0,0"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform x:Name="VisualizerKeycapScale"
                                                                            ScaleX="1"
                                                                            ScaleY="1" />
                                                            <TranslateTransform x:Name="VisualizerKeycapTranslate"
                                                                                Y="0" />
                                                        </TransformGroup>
                                                    </Border.RenderTransform>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#040B08"
                                                                          BlurRadius="14"
                                                                          ShadowDepth="4"
                                                                          Opacity="0.55" />
                                                    </Border.Effect>
                                                    <Grid>
                                                        <TextBlock x:Name="VisualizerKeycapLabel"
                                                                   Text="A"
                                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                                   FontSize="30"
                                                                   Foreground="#EEFFF8"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,0,0,8" />
                                                        <TextBlock x:Name="VisualizerKeycapState"
                                                                   Text="READY"
                                                                   Foreground="#9FD8C1"
                                                                   FontFamily="{StaticResource DashboardFontFamily}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Bottom"
                                                                   Margin="0,0,0,8" />
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <Border Margin="0,14,0,0"
                                                    Background="#172320"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="8"
                                                    Padding="10,8">
                                                <StackPanel>
                                                    <TextBlock Text="System Status"
                                                               FontSize="10"
                                                               Foreground="#7EB09A"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Row="2"
                                                Background="#172320"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="8"
                                                Padding="10,10">
                                            <StackPanel>
                                                <TextBlock Text="Volume Controls"
                                                           FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="Master, keyboard, and mouse vertical faders"
                                                           Margin="0,4,0,0"
                                                           Foreground="#8DC4AE"
                                                           FontSize="11" />

                                                <Grid Margin="0,12,0,0"
                                                      HorizontalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="Master"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding Volume, StringFormat={}{0:0}%}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,2,0,6" />
                                                        <Slider Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Style="{StaticResource VerticalVolumeSliderStyle}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="Keyboard"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding KeyboardVolume, StringFormat={}{0:0}%}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,2,0,6" />
                                                        <Slider Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding KeyboardVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Style="{StaticResource VerticalVolumeSliderStyle}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="Mouse"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="10"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding MouseVolume, StringFormat={}{0:0}%}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,2,0,6" />
                                                        <Slider Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding MouseVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Style="{StaticResource VerticalVolumeSliderStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="SoundProfilesSectionPanel"
                                    TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="SoundProfilesMainCard"
                                    Grid.Column="0"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#151E1B"
                                        Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Sound Profiles"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="18" />
                                        <TextBlock Text="Import packs, switch active profile, and manage imported sources."
                                                   Foreground="#8DC4AE"
                                                   FontSize="11"
                                                   Margin="0,4,0,10"
                                                   TextWrapping="Wrap" />

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ComboBox ItemsSource="{Binding KeyboardProfiles}"
                                                          SelectedItem="{Binding SelectedKeyboardProfile}"
                                                          ItemTemplate="{StaticResource ProfileItemTemplate}"
                                                          MinHeight="38"
                                                          Padding="10,6,84,6"
                                                          Margin="0,0,8,0" />

                                                <Button Grid.Column="1"
                                                        Width="38"
                                                        Height="38"
                                                        ToolTip="Import keyboard pack"
                                                        Command="{Binding ImportKeyboardSoundPackCommand}"
                                                        Style="{StaticResource GlowButtonStyle}"
                                                        Padding="0">
                                                    <TextBlock Text="+"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ComboBox ItemsSource="{Binding MouseProfiles}"
                                                          SelectedItem="{Binding SelectedMouseProfile}"
                                                          ItemTemplate="{StaticResource ProfileItemTemplate}"
                                                          MinHeight="38"
                                                          Padding="10,6,84,6"
                                                          Margin="0,0,8,0" />

                                                <Button Grid.Column="1"
                                                        Width="38"
                                                        Height="38"
                                                        ToolTip="Import mouse pack"
                                                        Command="{Binding ImportMouseSoundPackCommand}"
                                                        Style="{StaticResource GlowButtonStyle}"
                                                        Padding="0">
                                                    <TextBlock Text="+"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>
                                        </Grid>

                                        <TextBlock Text="Available Profiles"
                                                   Margin="0,12,0,8"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" />

                                        <Border Background="#111917"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                                CornerRadius="8"
                                                Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Grid Margin="2,0,2,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="42" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Type"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="Profile"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="Source"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="Action"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                </Grid>

                                                <ScrollViewer Grid.Row="1"
                                                              MaxHeight="232"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <ItemsControl ItemsSource="{Binding Profiles}"
                                                                  ItemTemplate="{StaticResource ProfileTableRowTemplate}" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#111917"
                                    Padding="12"
                                    VerticalAlignment="Top"
                                    MaxHeight="{Binding ActualHeight, ElementName=SoundProfilesMainCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Live Activity"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1"
                                                   Text="Inspired by Mechvibes system logs"
                                                   Foreground="#8DC4AE"
                                                   FontSize="11"
                                                   Margin="0,4,0,10" />

                                        <Border Grid.Row="2"
                                                Background="#172320"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="8"
                                                ClipToBounds="True"
                                                Padding="8">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       FontFamily="Consolas"
                                                                       Foreground="#CFECE0"
                                                                       FontSize="10"
                                                                       Margin="0,0,0,5"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="KeyMappingsSectionPanel"
                            TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Border Background="#151E1B"
                                Style="{StaticResource ModernCardStyle}"
                                    Padding="14">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Key Mappings"
                                                       FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="18" />
                                            <TextBlock Text="Detailed keyboard mapping controls"
                                                       Foreground="#8DC4AE"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Command="{Binding AddKeyboardMappingCommand}"
                                                ToolTip="Add keyboard mapping"
                                                Width="34"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding ClearMappingsCommand}"
                                            Margin="12,0,0,0"
                                                Height="34"
                                            MinWidth="84"
                                            Padding="16,0"
                                                Style="{StaticResource ClearButtonStyle}">
                                            <TextBlock Text="Clear"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Click a key cell to capture a new keyboard input."
                                               Foreground="#8DC4AE"
                                               FontSize="11"
                                               Margin="0,8,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                                  ItemTemplate="{StaticResource MappingRowTemplate}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel x:Name="MouseSettingsSectionPanel"
                            TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Border Background="#151E1B"
                                Style="{StaticResource ModernCardStyle}"
                                    Padding="14">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Mouse Mappings"
                                                       FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="18" />
                                            <TextBlock Text="Detailed mouse mapping controls"
                                                       Foreground="#8DC4AE"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Command="{Binding AddMouseMappingCommand}"
                                                ToolTip="Add mouse mapping"
                                                Width="34"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding ClearMappingsCommand}"
                                            Margin="12,0,0,0"
                                                Height="34"
                                            MinWidth="84"
                                            Padding="16,0"
                                                Style="{StaticResource ClearButtonStyle}">
                                            <TextBlock Text="Clear"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

