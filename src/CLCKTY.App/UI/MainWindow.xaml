                                        <Grid Margin="0,4,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="PackNameTextBox"
                                                     Text="My Custom Pack"
                                                     Margin="0,0,8,0"
                                                     MinHeight="34"
                                                     Padding="8,6"
                                                     Background="#10221B"
                                                     BorderBrush="#2B6D56"
                                                     BorderThickness="1"
                                                     Foreground="#E8FFF5"
                                                     CaretBrush="#22D883" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GlowButtonStyle}"
                                                    MinWidth="96"
                                                    Height="40"
                                                    Click="CreatePackButton_Click">
                                                <TextBlock Text="Create"
                                                           FontSize="14"
                                                           FontWeight="SemiBold" />
                                            </Button>
                                        </Grid>

                                        <Button Style="{StaticResource GlowButtonStyle}"
                                                Click="BulkUploadButton_Click"
                                                Height="38"
                                                Padding="14,0"
                                                Margin="0,0,0,10">
                                            <TextBlock Text="Choose Files to Upload"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                        </Button>

                                        <Button x:Name="SavePackageButton"
                                            Style="{StaticResource GlowButtonStyle}"
                                                Click="SavePackageButton_Click"
                                                Height="38"
                                                Padding="14,0"
                                                Margin="0,0,0,10">
                                            <TextBlock Text="Save Package"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                        </Button>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="RecordButton"
                                                    Width="56"
                                                    Height="56"
                                                    Margin="0,0,14,0"
                                                    Background="#5C1A18"
                                                    BorderBrush="#D32F2F"
                                                    BorderThickness="2"
                                                    Foreground="White"
                                                    Style="{StaticResource GlowButtonStyle}"
                                                    Click="RecordButton_Click">
                                                <TextBlock x:Name="RecordButtonIcon"
                                                           Text="&#xE720;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Button>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="RecordingStatusText"
                                                           Text="Ready to record"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13" />
                                                <TextBlock x:Name="RecordingTimerText"
                                                           Text="0.0 / 2.5 sec"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="11"
                                                           Margin="0,3,0,0" />
                                                <Grid Margin="0,6,0,0" Height="6">
                                                    <Border CornerRadius="3" Background="#132A22" />
                                                    <Border x:Name="RecordingProgressFill"
                                                            CornerRadius="3"
                                                            Background="#D32F2F"
                                                            HorizontalAlignment="Left"
                                                            Width="0" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock x:Name="PackStatusText"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0"
                                        Grid.Column="2"
                                        Background="#111917"
                                        Style="{StaticResource ModernCardStyle}"
                                        Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Sounds in Pack"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />
                                        <TextBlock x:Name="PackSoundCountText"
                                                   Text="0 sounds"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,2,0,8" />
                                        <ScrollViewer MaxHeight="320"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="PackSoundsPanel">
                                                <TextBlock Text="No sounds added yet."
                                                           Foreground="#5B8A76"
                                                           FontStyle="Italic"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Background="#111917"
                                        BorderBrush="#2A6A53"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Packages Created"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13" />
                                        <TextBlock x:Name="CreatedPackagesCountText"
                                                   Text="0 package(s)"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="10"
                                                   Margin="0,2,0,8" />
                                        <ScrollViewer MaxHeight="160"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="CreatedPackagesPanel">
                                                <TextBlock Text="No packages created yet."
                                                           Foreground="#5B8A76"
                                                           FontStyle="Italic"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
