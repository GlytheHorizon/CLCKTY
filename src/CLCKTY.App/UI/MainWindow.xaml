<Window x:Class="CLCKTY.App.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:CLCKTY.App.UI"
        mc:Ignorable="d"
        Title="CLCKTY"
        Width="430"
        Height="600"
        MinWidth="430"
        MaxWidth="430"
        MinHeight="600"
        MaxHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Opacity="0">
    <Window.Resources>
        <LinearGradientBrush x:Key="PanelBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#141820" Offset="0.0" />
            <GradientStop Color="#11141B" Offset="0.55" />
            <GradientStop Color="#1A1D2B" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F6F8FF" />
            <Setter Property="Background" Value="#242C3D" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#3A4663" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="#4F6BFF" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#2B3651" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="15"
                                    Background="#313949" />
                            <Border x:Name="Thumb"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="#EDF0FF"
                                    Margin="3"
                                    HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#4F6BFF" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="28"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F4F6FF" />
            <Setter Property="Background" Value="#1E2432" />
            <Setter Property="BorderBrush" Value="#2F3950" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="6">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="\u25BE"
                                               Foreground="#A9B8E6"
                                               Margin="6,0,4,0"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Right" />
                                    <ContentPresenter Margin="4,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}" />
                                </DockPanel>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=Bd}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#0F1320"
                                        BorderBrush="#2F3950"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Foreground" Value="#DDE8FF" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter Margin="6,0" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#172036" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#2B3651" />
                                            <Setter Property="Foreground" Value="#EEF4FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="22"
            BorderBrush="#2F3950"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#0A0D15"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.75" />
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1C2231"
                    BorderBrush="#32405A"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="CLCKTY"
                                   FontSize="24"
                                   FontFamily="Segoe UI Semibold"
                                   Foreground="#EFF3FF" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#7A8498" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Fill" Value="#2CE086" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock FontSize="12"
                                       Foreground="#9FAED0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Muted" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Text" Value="Active" />
                                                <Setter Property="Foreground" Value="#B5C8FF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Content="X"
                            FontSize="12"
                            Style="{StaticResource GlowButtonStyle}"
                            Click="HideButton_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Sound Profile"
                           FontSize="12"
                           Foreground="#A7B4D4"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="DisplayName"
                              MinHeight="38"
                              Margin="0,0,10,0" />

                    <Button Grid.Column="1"
                            Content="Import Pack"
                            Command="{Binding ImportSoundPackCommand}"
                            Style="{StaticResource GlowButtonStyle}"
                            MinHeight="38" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Volume"
                           FontSize="12"
                           Foreground="#A7B4D4"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Foreground="#4F6BFF" />

                    <Border Grid.Column="1"
                            Background="#1E2536"
                            CornerRadius="8"
                            BorderBrush="#37445E"
                            BorderThickness="1"
                            Padding="10,6">
                        <TextBlock Foreground="#D9E4FF"
                                   FontWeight="SemiBold"
                                   Text="{Binding Volume, StringFormat={}{0:0}%}" />
                    </Border>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Enable Keyboard Sounds"
                               Foreground="#DDE5FF"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Global hook active, no keystrokes stored"
                               Foreground="#8E9DBE"
                               FontSize="12"
                               Margin="0,3,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <ToggleButton Style="{StaticResource SwitchStyle}"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                    <CheckBox Margin="0,10,0,0"
                              Foreground="#B4C1DF"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                              Content="Start with Windows" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="8"
                    Background="#171D2B"
                    BorderBrush="#2F3A53"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Expander Header="Per-Key Mapping (Optional)"
                          IsExpanded="False"
                          Foreground="#EAF0FF"
                          Background="Transparent">
                    <StackPanel Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding KeyMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type ui:KeyMappingRowViewModel}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="118" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Background="#1F2738"
                                                BorderBrush="#37435E"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,8"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding KeyLabel}"
                                                       Foreground="#E7EEFF"
                                                       FontWeight="SemiBold" />
                                        </Border>

                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding SelectedClipId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  MinHeight="34" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="Clear Custom Mappings"
                                Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding ClearMappingsCommand}"
                                Style="{StaticResource GlowButtonStyle}" />
                    </StackPanel>
                </Expander>
            </Border>

            <Border Grid.Row="10"
                    Background="#121725"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#293246"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#CBDAFF"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="CLCKTY only triggers playback and never logs typing."
                               Foreground="#8FA0C4"
                               FontSize="11"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
