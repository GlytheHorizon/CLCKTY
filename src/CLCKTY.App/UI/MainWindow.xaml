                                            <TextBlock Text="{Binding StatusText}"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                    Style="{StaticResource ModernCardStyle}"
                                    Background="#151E1B"
                                    Padding="12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Key Mapping"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />

                                        <Button Grid.Column="1"
                                                Command="{Binding AddKeyboardMappingCommand}"
                                                ToolTip="Add keyboard mapping"
                                                Width="30"
                                                Height="30"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Press +, then press a key to capture mapping input."
                                               Foreground="#8DC4AE"
                                               FontSize="11"
                                               Margin="0,4,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                                  ItemTemplate="{StaticResource MappingRowTemplate}" />
                                </StackPanel>
                            </Border>

                                <Border Grid.Column="2"
                                    Style="{StaticResource ModernCardStyle}"
                                    Background="#151E1B"
                                    Padding="12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Mouse Mappings"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />

                                        <Button Grid.Column="1"
                                                Command="{Binding AddMouseMappingCommand}"
                                                ToolTip="Add mouse mapping"
                                                Width="30"
                                                Height="30"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Click an input field, then click a mouse button to capture mapping."
                                               Foreground="#8DC4AE"
                                               FontSize="11"
                                               Margin="0,4,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding MouseMappings}"
                                                  ItemTemplate="{StaticResource MappingRowTemplate}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Margin="0,12,0,0"
                            Style="{StaticResource ModernCardStyle}"
                                Background="#0F1E18"
                                Padding="12"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="CLCKTY only triggers playback and never logs typing."
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        </StackPanel>

                        <StackPanel x:Name="SoundProfilesSectionPanel"
                                    TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#151E1B"
                                        Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="Sound Profiles"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="18" />
                                        <TextBlock Text="Import packs, switch active profile, and manage imported sources."
                                                   Foreground="#8DC4AE"
                                                   FontSize="11"
                                                   Margin="0,4,0,10"
                                                   TextWrapping="Wrap" />

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ComboBox ItemsSource="{Binding KeyboardProfiles}"
                                                          SelectedItem="{Binding SelectedKeyboardProfile}"
                                                          ItemTemplate="{StaticResource ProfileItemTemplate}"
                                                          MinHeight="38"
                                                          Padding="10,6,84,6"
                                                          Margin="0,0,8,0" />

                                                <Button Grid.Column="1"
                                                        Width="38"
                                                        Height="38"
                                                        ToolTip="Import keyboard pack"
                                                        Command="{Binding ImportKeyboardSoundPackCommand}"
                                                        Style="{StaticResource GlowButtonStyle}"
                                                        Padding="0">
                                                    <TextBlock Text="+"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ComboBox ItemsSource="{Binding MouseProfiles}"
                                                          SelectedItem="{Binding SelectedMouseProfile}"
                                                          ItemTemplate="{StaticResource ProfileItemTemplate}"
                                                          MinHeight="38"
                                                          Padding="10,6,84,6"
                                                          Margin="0,0,8,0" />

                                                <Button Grid.Column="1"
                                                        Width="38"
                                                        Height="38"
                                                        ToolTip="Import mouse pack"
                                                        Command="{Binding ImportMouseSoundPackCommand}"
                                                        Style="{StaticResource GlowButtonStyle}"
                                                        Padding="0">
                                                    <TextBlock Text="+"
                                                               FontSize="18"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </Grid>
                                        </Grid>

                                        <TextBlock Text="Available Profiles"
                                                   Margin="0,12,0,8"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" />

                                        <Border Background="#111917"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                                CornerRadius="8"
                                                Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Grid Margin="2,0,2,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="42" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Type"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="Profile"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="Source"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="Action"
                                                               Foreground="#8DC4AE"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                </Grid>

                                                <ScrollViewer Grid.Row="1"
                                                              MaxHeight="232"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <ItemsControl ItemsSource="{Binding Profiles}"
                                                                  ItemTemplate="{StaticResource ProfileTableRowTemplate}" />
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource ModernCardStyle}"
                                        Background="#111917"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Live Activity"
                                                   FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1"
                                                   Text="Inspired by Mechvibes system logs"
                                                   Foreground="#8DC4AE"
                                                   FontSize="11"
                                                   Margin="0,4,0,10" />

                                        <Border Grid.Row="2"
                                                Background="#172320"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="8"
                                                ClipToBounds="True"
                                                Padding="8">
                                            <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontFamily="Consolas"
                                                                   Foreground="#CFECE0"
                                                                   FontSize="10"
                                                                   Margin="0,0,0,5"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="KeyMappingsSectionPanel"
                            TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Border Background="#151E1B"
                                Style="{StaticResource ModernCardStyle}"
                                    Padding="14">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Key Mappings"
                                                       FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="18" />
                                            <TextBlock Text="Detailed keyboard mapping controls"
                                                       Foreground="#8DC4AE"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Command="{Binding AddKeyboardMappingCommand}"
                                                ToolTip="Add keyboard mapping"
                                                Width="34"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding ClearMappingsCommand}"
                                            Margin="12,0,0,0"
                                                Height="34"
                                            MinWidth="84"
                                            Padding="16,0"
                                                Style="{StaticResource ClearButtonStyle}">
                                            <TextBlock Text="Clear"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Click a key cell to capture a new keyboard input."
                                               Foreground="#8DC4AE"
                                               FontSize="11"
                                               Margin="0,8,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                                  ItemTemplate="{StaticResource MappingRowTemplate}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel x:Name="MouseSettingsSectionPanel"
                            TextElement.FontFamily="{StaticResource DashboardFontFamily}"
                                    Visibility="Collapsed">
                            <Border Background="#151E1B"
                                Style="{StaticResource ModernCardStyle}"
                                    Padding="14">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Mouse Mappings"
                                                       FontFamily="{StaticResource DashboardHeadingFontFamily}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="18" />
                                            <TextBlock Text="Detailed mouse mapping controls"
                                                       Foreground="#8DC4AE"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Command="{Binding AddMouseMappingCommand}"
                                                ToolTip="Add mouse mapping"
                                                Width="34"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource GlowButtonStyle}"
                                                Padding="0">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE710;"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding ClearMappingsCommand}"
                                            Margin="12,0,0,0"
                                                Height="34"
                                            MinWidth="84"
                                            Padding="16,0"
                                                Style="{StaticResource ClearButtonStyle}">
                                            <TextBlock Text="Clear"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Click a mapping input, then click any mouse button to capture it."
                                               Foreground="#8DC4AE"
                                               FontSize="11"
                                               Margin="0,8,0,10"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding MouseMappings}"
                                                  ItemTemplate="{StaticResource MappingRowTemplate}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
