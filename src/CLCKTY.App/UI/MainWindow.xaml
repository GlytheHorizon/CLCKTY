<Window x:Class="CLCKTY.App.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CLCKTY.App.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:CLCKTY.App.UI"
        mc:Ignorable="d"
        Title="CLCKTY"
        Width="980"
        Height="620"
        MinWidth="980"
        MaxWidth="980"
        MinHeight="620"
        MaxHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Opacity="0">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1FC374" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#123025" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#0E1D17" />

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#2A6A53" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#DDFCEF" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderIconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderIconRoot" Property="Background" Value="#1D4937" />
                                <Setter TargetName="HeaderIconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderIconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource HeaderIconButtonStyle}">
            <Setter Property="Foreground" Value="#FFE2DE" />
            <Setter Property="Background" Value="#3A1A16" />
            <Setter Property="BorderBrush" Value="#7A433B" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderCloseRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderCloseRoot" Property="Background" Value="#5C2621" />
                                <Setter TargetName="HeaderCloseRoot" Property="BorderBrush" Value="#F08E82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderCloseRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Foreground" Value="#FFD8D2" />
            <Setter Property="Background" Value="#341916" />
            <Setter Property="BorderBrush" Value="#7A3F38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DangerRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DangerRoot" Property="Background" Value="#522521" />
                                <Setter TargetName="DangerRoot" Property="BorderBrush" Value="#F1968A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DangerRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DangerRoot" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Width="22" Height="22">
                            <Ellipse Fill="#EFFFF8"
                                     Stroke="#134232"
                                     StrokeThickness="2" />
                            <Ellipse Fill="{StaticResource AccentBrush}"
                                     Width="8"
                                     Height="8"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderTrackFillStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="8"
                                CornerRadius="4"
                                Background="{StaticResource AccentBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderTrackRestStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="8"
                                CornerRadius="4"
                                Background="#254D3D" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VolumeSliderTrackFillStyle}"
                                                  Command="Slider.DecreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource VolumeSliderTrackRestStyle}"
                                                  Command="Slider.IncreaseLarge" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource VolumeSliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="14"
                                    Background="#244437" />
                            <Border x:Name="Thumb"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="#E8FFF5"
                                    Margin="3"
                                    HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="24"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10221B" />
            <Setter Property="BorderBrush" Value="#2B6D56" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />

                            <Grid Margin="10,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  SnapsToDevicePixels="True" />

                                <Path Grid.Column="1"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#9CD9C2"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource PopupBackgroundBrush}"
                                        BorderBrush="#2B6D56"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#D9F6EB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#144131" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A5A43" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProfileItemTemplate" DataType="{x:Type core:SoundProfileDescriptor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0" />

                <Border Grid.Column="1"
                        Padding="7,2"
                        CornerRadius="8"
                    Margin="0,0,6,0"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#173629" />
                            <Setter Property="BorderBrush" Value="#2A7C5E" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImported}" Value="True">
                                    <Setter Property="Background" Value="#1A5A43" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SourceLabel}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>

                <Button Grid.Column="2"
                        Width="26"
                        Height="26"
                        ToolTip="Delete imported pack"
                        Click="DeleteProfileOptionButton_Click"
                        Focusable="False"
                        IsTabStop="False">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerIconButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImported}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74D;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MappingSoundOptionTemplate" DataType="{x:Type ui:KeyMappingOption}">
            <TextBlock Text="{Binding DisplayLabel}" />
        </DataTemplate>

        <Style x:Key="MappingSoundOptionItemStyle"
               TargetType="ComboBoxItem"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="8,5,8,5"
                                                  VerticalAlignment="Center" />

                                <Button x:Name="DeleteClipButton"
                                        Grid.Column="1"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        ToolTip="Delete this sound"
                                        Visibility="Collapsed"
                                        Focusable="False"
                                        IsTabStop="False"
                                    Click="DeleteClipOptionButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GlowButtonStyle}">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Background" Value="#1E3A2D" />
                                            <Setter Property="BorderBrush" Value="#2A6A53" />
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE74D;"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#144131" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A5A43" />
                            </Trigger>
                            <DataTrigger Binding="{Binding CanRemove}" Value="True">
                                <Setter TargetName="DeleteClipButton" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="MappingRowTemplate" DataType="{x:Type ui:KeyMappingRowViewModel}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{Binding InputLabel}"
                        Command="{Binding DataContext.CaptureKeyboardInputCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Focusable="False"
                        IsTabStop="False"
                        MinHeight="34">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GlowButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Padding" Value="10,8" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseMapping}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCapturingInput}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="#07241A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding InputOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding InputCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseMapping}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Options}"
                          DisplayMemberPath="DisplayLabel"
                          ItemTemplate="{StaticResource MappingSoundOptionTemplate}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedClipId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemContainerStyle="{StaticResource MappingSoundOptionItemStyle}"
                          Margin="8,0,0,0" />

                <Button Grid.Column="2"
                        ToolTip="Upload sound for this mapping"
                        Command="{Binding DataContext.ImportMappingAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE898;"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>

                <Button Grid.Column="3"
                        Content="-"
                        Command="{Binding DataContext.RemoveMappingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="22"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#04120D"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.75" />
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="44"
                                Height="44"
                                CornerRadius="10"
                                Background="#123126"
                                BorderBrush="#285A48"
                                BorderThickness="1"
                                Margin="0,0,12,0">
                            <Image Source="pack://siteoforigin:,,,/Assets/Icons/clckty-app.png"
                                   Stretch="Uniform"
                                   Margin="5" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Clckty"
                                       FontSize="24"
                                       FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                                       Foreground="{StaticResource TextPrimaryBrush}" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,4,0,0"
                                        VerticalAlignment="Center">
                                <Ellipse Width="8"
                                         Height="8"
                                         Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#5B7B70" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Muted" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Text" Value="Active" />
                                                    <Setter Property="Foreground" Value="#C6FBE5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center">
                        <Button ToolTip="Information"
                                Style="{StaticResource HeaderIconButtonStyle}"
                                Click="InfoButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE946;"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button ToolTip="Settings"
                                Margin="8,0,0,0"
                                Style="{StaticResource HeaderIconButtonStyle}"
                                Click="SettingsButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE713;"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Margin="8,0,0,0"
                                ToolTip="Hide to tray"
                                Style="{StaticResource HeaderCloseButtonStyle}"
                                Click="HideButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE711;"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Sound Profile"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="0,0,10,0">
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  ItemTemplate="{StaticResource ProfileItemTemplate}"
                                  MinHeight="38"
                                  Padding="10,6,88,6" />
                    </Grid>

                    <Button Grid.Column="1"
                            Width="38"
                            Height="38"
                            ToolTip="Import pack"
                            Command="{Binding ImportSoundPackCommand}"
                            Style="{StaticResource GlowButtonStyle}"
                            Padding="0">
                        <TextBlock Text="+"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Volume"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Style="{StaticResource VolumeSliderStyle}" />

                    <Border Grid.Column="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            Padding="10,6">
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding Volume, StringFormat={}{0:0}%}" />
                    </Border>
                </Grid>

            </StackPanel>

            <Border Grid.Row="6"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12,14,12,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="4,10,4,4">
                        <TextBlock Text="Mappings"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="16" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Key Mapping"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Click + and press the keyboard key you want to map."
                                           Foreground="#8DC4AE"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Command="{Binding AddKeyboardMappingCommand}"
                                        ToolTip="Add keyboard mapping"
                                        HorizontalAlignment="Left"
                                        Width="34"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE710;"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>

                                <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="1"
                                    HorizontalAlignment="Center"
                                    Background="#1E4A3A"
                                    Margin="5,2" />

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mouse Mapping"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Click + to add mouse button mappings and assign sounds."
                                           Foreground="#8DC4AE"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Command="{Binding AddMouseMappingCommand}"
                                        ToolTip="Add mouse mapping"
                                        HorizontalAlignment="Left"
                                        Width="34"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE710;"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>

                                <ItemsControl ItemsSource="{Binding MouseMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />
                            </StackPanel>
                        </Grid>

                        <Button Content="Clear Custom Mappings"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding ClearMappingsCommand}"
                                Style="{StaticResource GlowButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="8"
                    Background="#0F1E18"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="CLCKTY only triggers playback and never logs typing."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
