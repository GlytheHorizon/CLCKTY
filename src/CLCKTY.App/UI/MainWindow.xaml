<Window x:Class="CLCKTY.App.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:CLCKTY.App.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:CLCKTY.App.UI"
        mc:Ignorable="d"
        Title="CLCKTY"
        Width="980"
        Height="620"
        MinWidth="980"
        MaxWidth="980"
        MinHeight="620"
        MaxHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Opacity="0">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1FC374" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#123025" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#0E1D17" />

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#2A6A53" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="14"
                                    Background="#244437" />
                            <Border x:Name="Thumb"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="#E8FFF5"
                                    Margin="3"
                                    HorizontalAlignment="Left">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="24"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#10221B" />
            <Setter Property="BorderBrush" Value="#2B6D56" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" />

                            <Grid Margin="10,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  SnapsToDevicePixels="True" />

                                <Path Grid.Column="1"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="#9CD9C2"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource PopupBackgroundBrush}"
                                        BorderBrush="#2B6D56"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#D9F6EB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#144131" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A5A43" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ProfileItemTemplate" DataType="{x:Type core:SoundProfileDescriptor}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0" />

                <Border Grid.Column="1"
                        Padding="7,2"
                        CornerRadius="8"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#173629" />
                            <Setter Property="BorderBrush" Value="#2A7C5E" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImported}" Value="True">
                                    <Setter Property="Background" Value="#1A5A43" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SourceLabel}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MappingRowTemplate" DataType="{x:Type ui:KeyMappingRowViewModel}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{Binding InputLabel}"
                        Command="{Binding DataContext.CaptureKeyboardInputCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Focusable="False"
                        IsTabStop="False"
                        MinHeight="34">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GlowButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Padding" Value="10,8" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseMapping}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCapturingInput}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="#07241A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding InputOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding InputCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseMapping}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                    <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Options}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedClipId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Margin="8,0,0,0" />

                    <Button Grid.Column="2"
                        Content="{Binding AudioButtonLabel}"
                        ToolTip="{Binding SelectedClipDisplayName}"
                        Command="{Binding DataContext.ImportMappingAudioCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}" />

                    <Button Grid.Column="3"
                        Content="-"
                        Command="{Binding DataContext.RemoveMappingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="8,0,0,0"
                        MinHeight="34"
                        Style="{StaticResource GlowButtonStyle}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="22"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#04120D"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.75" />
        </Border.Effect>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="CLCKTY"
                                   FontSize="24"
                                   FontFamily="Segoe UI Semibold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#5B7B70" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Muted" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Text" Value="Active" />
                                                <Setter Property="Foreground" Value="#C6FBE5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="14,0,12,0"
                                VerticalAlignment="Center">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Master"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Key"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsKeyboardSoundEnabled, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Mouse"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <ToggleButton Style="{StaticResource SwitchStyle}"
                                          IsChecked="{Binding IsMouseSoundEnabled, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="28"
                            Height="28"
                            Content="X"
                            FontSize="12"
                            Style="{StaticResource GlowButtonStyle}"
                            Click="HideButton_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Sound Profile"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="0,0,10,0">
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  ItemTemplate="{StaticResource ProfileItemTemplate}"
                                  MinHeight="38"
                                  Padding="10,6,88,6" />
                    </Grid>

                    <Button Grid.Column="1"
                            Content="Import Pack"
                            Command="{Binding ImportSoundPackCommand}"
                            Style="{StaticResource GlowButtonStyle}"
                            MinHeight="38" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Volume"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="2,0,0,6" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Foreground="{StaticResource AccentBrush}" />

                    <Border Grid.Column="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            Padding="10,6">
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding Volume, StringFormat={}{0:0}%}" />
                    </Border>
                </Grid>

                <CheckBox Margin="2,10,0,0"
                          Foreground="{StaticResource TextSecondaryBrush}"
                          IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                          Content="Start with Windows" />
            </StackPanel>

            <Border Grid.Row="6"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12,14,12,12">
                <TabControl Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,2,0,0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="Background" Value="#123226" />
                            <Setter Property="BorderBrush" Value="#245D48" />
                            <Setter Property="MinHeight" Value="42" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Margin" Value="0,0,6,0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="TabRoot"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8,8,0,0"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabRoot" Property="Background" Value="#1A5A43" />
                                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="Sound">
                        <StackPanel Margin="4,10,4,4">
                            <TextBlock Text="Use the profile dropdown to switch between stock and imported packs instantly."
                                       Foreground="#C9F2E2"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,10,0,0"
                                    Background="#143227"
                                    BorderBrush="#2B7058"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Current Source"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,8,0" />
                                    <Border Padding="8,2"
                                            CornerRadius="8"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#173629" />
                                                <Setter Property="BorderBrush" Value="#2A7C5E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedProfile.IsImported}" Value="True">
                                                        <Setter Property="Background" Value="#1A5A43" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding SelectedProfile.SourceLabel}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,10,0,0"
                                       Text="Map any key or mouse button in the Key Mapping tab and assign a single clip per input."
                                       Foreground="#92CAB3"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Key Mapping">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,10,4,4">
                                <TextBlock Text="Keyboard Mappings"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Add a row, click its key button, then press the key you want to map."
                                           Foreground="#8DC4AE"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Content="Add Keyboard Mapping"
                                        Command="{Binding AddKeyboardMappingCommand}"
                                        HorizontalAlignment="Left"
                                        MinHeight="32"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}" />

                                <ItemsControl ItemsSource="{Binding KeyboardMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />

                                <Border Height="1"
                                        Margin="0,10,0,10"
                                    Background="#1E4A3A" />

                                <TextBlock Text="Mouse Mappings"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Map left, right, middle, or side mouse buttons with one clip per button."
                                       Foreground="#8DC4AE"
                                           FontSize="11"
                                           Margin="0,2,0,8"
                                           TextWrapping="Wrap" />

                                <Button Content="Add Mouse Mapping"
                                        Command="{Binding AddMouseMappingCommand}"
                                        HorizontalAlignment="Left"
                                        MinHeight="32"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GlowButtonStyle}" />

                                <ItemsControl ItemsSource="{Binding MouseMappings}"
                                              ItemTemplate="{StaticResource MappingRowTemplate}" />

                                <Button Content="Clear Custom Mappings"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ClearMappingsCommand}"
                                        Style="{StaticResource GlowButtonStyle}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="8"
                    Background="#0F1E18"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="CLCKTY only triggers playback and never logs typing."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
