<Window x:Class="CLCKTY.App.UI.RecordItWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record It"
        Width="540"
        Height="580"
        MinWidth="540"
        MaxWidth="540"
        MinHeight="580"
        MaxHeight="580"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#0B1713" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#1C4A3B" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#10201A" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#1E5B46" />
        <SolidColorBrush x:Key="AccentBrush" Color="#22D883" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8FFF5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FD8C1" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E3FCF1" />
            <Setter Property="Background" Value="#173427" />
            <Setter Property="BorderBrush" Value="#2B7058" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="IconRoot" Property="Background" Value="#1D4937" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#123025" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#2A6A53" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#1A4A38" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecordButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#5C1A18" />
            <Setter Property="BorderBrush" Value="#D32F2F" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RecordRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="28">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RecordRoot" Property="Background" Value="#D32F2F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RecordRoot" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFDCD7" />
            <Setter Property="Background" Value="#2C1A18" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#8A4D45" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DangerRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DangerRoot" Property="Background" Value="#4B2622" />
                                <Setter TargetName="DangerRoot" Property="BorderBrush" Value="#D17B71" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#2A6A53"
                                BorderBrush="#3E8A6D"
                                BorderThickness="1"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="#0E1D17" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="1">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource ScrollBarRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource PanelBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#xE7C8;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="22"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Record It"
                               FontFamily="/CLCKTY.App;component/Assets/Fonts/#Splatink PERSONAL USE"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Create your own custom sound packs"
                               Margin="0,2,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <Button Grid.Column="2"
                        ToolTip="Close"
                        Style="{StaticResource IconButtonStyle}"
                        Click="CloseButton_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Create Pack Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Create New Pack"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="15" />
                            <TextBlock Text="Name your pack and add sounds via upload or microphone recording."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,4,0,10"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Pack Name"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Background="#10221B"
                                        BorderBrush="#2B6D56"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="0,0,8,0">
                                    <TextBox x:Name="PackNameTextBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#E8FFF5"
                                             CaretBrush="#22D883"
                                             FontSize="13"
                                             Text="My Custom Pack" />
                                </Border>

                                <Button Grid.Column="1"
                                        Style="{StaticResource GlowButtonStyle}"
                                        Click="CreatePackButton_Click"
                                        Padding="14,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Create"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock x:Name="PackStatusText"
                                       Text=""
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Upload Sounds Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE898;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Upload Sounds"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="Select multiple audio files to add to the current pack."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,10"
                                       TextWrapping="Wrap" />

                            <Button Style="{StaticResource GlowButtonStyle}"
                                    Click="BulkUploadButton_Click"
                                    Padding="12,10"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="&#xED25;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Choose Files to Upload"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Record Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE720;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Foreground="#FF5252"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Record from Microphone"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                            </StackPanel>
                            <TextBlock Text="Record a short sound effect (max 5 seconds)."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,14"
                                       TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="RecordButton"
                                        Style="{StaticResource RecordButtonStyle}"
                                        Click="RecordButton_Click"
                                        Margin="0,0,14,0">
                                    <TextBlock x:Name="RecordButtonIcon"
                                               Text="&#xE720;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="RecordingStatusText"
                                               Text="Ready to record"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock x:Name="RecordingTimerText"
                                               Text="0.0 / 5.0 sec"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0,3,0,0" />

                                    <!-- Recording progress bar -->
                                    <Grid Margin="0,6,0,0" Height="6">
                                        <Border CornerRadius="3"
                                                Background="#132A22" />
                                        <Border x:Name="RecordingProgressFill"
                                                CornerRadius="3"
                                                Background="#D32F2F"
                                                HorizontalAlignment="Left"
                                                Width="0" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Files in Pack Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Sounds in Pack"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                            <TextBlock x:Name="PackSoundCountText"
                                       Text="0 sounds"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,8" />

                            <ScrollViewer MaxHeight="140"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="PackSoundsPanel">
                                    <TextBlock Text="No sounds added yet."
                                               Foreground="#5B8A76"
                                               FontStyle="Italic"
                                               FontSize="11" />
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
